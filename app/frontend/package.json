    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
